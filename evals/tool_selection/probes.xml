<probes>
  <!--
    Tool-selection probes for the rcsb-mcp server (see README.md).

    Each probe is a natural-language prompt plus an assertion over the model's FIRST tool
    call. This suite grades the ROUTING DECISION, not the answer — it is the complement of
    rcsb_pdb_eval.xml, which grades final answers and (by design, since its answers must be
    stable) never exercises the rcsb_search_* tools at all.

    Run it BEFORE vs AFTER a change (e.g. a docstring trim) and compare pass RATES; a case
    that is already <100% on both sides is a pre-existing limitation, not a regression.

    <expect> vocabulary (ALL children must hold — they are AND-ed):
      <expect tool="X">              first call must be tool X
      <expect tool-in="X,Y">         first call must be one of X, Y
      <expect tool-not="X">          first call must NOT be X
      <expect>                       (no tool attr) assert only on the arguments
        <arg name="n" equals="v"/>             args[n] == v   (add default="d" to treat a
                                               missing arg as d; ignore-case="true" to
                                               compare case-insensitively; "true"/"false"
                                               compare against booleans)
        <arg name="n" set="true"/>             args[n] is present and non-empty
        <arg name="n" contains="s"/>           s is a substring of str(args[n])
        <attribute path="p" operator="o"/>     args["attributes"] contains an entry whose
                                               attribute path contains p (and whose operator
                                               is o, when given)

    Assertions are deliberately tolerant (substring / operator matching) so a
    correct-but-differently-phrased call still passes.

    probe attributes:
      id     — stable identifier (used by the "only" filter and in reports)
      probes — what behaviour this asserts, shown in the report
      seed   — optional conversation seeding; "zero-result" primes the model with a prior
               attribute search that returned 0 hits, then asks a follow-up
  -->

  <probe id="kw-routing" probes="keyword routing (no clear attribute)">
    <prompt>Find PDB structures related to CRISPR immunity.</prompt>
    <expect tool="rcsb_search_fulltext"/>
  </probe>

  <probe id="attr-vs-kw" probes="attribute vs keyword">
    <prompt>List X-ray structures with resolution better than 1.5 Angstrom.</prompt>
    <expect tool="rcsb_search_by_attribute">
      <attribute path="resolution_combined" operator="less"/>
    </expect>
  </probe>

  <probe id="ontology-disease" probes="ontology routing (list moved to instructions) -> resolver first">
    <prompt>Find structures associated with cystic fibrosis.</prompt>
    <expect tool="rcsb_find_disease_terms"/>
  </probe>

  <!--
    First-call probe for the group_by MECHANIC. The subject is pre-resolved (an InterPro id)
    so the model shouldn't need a resolver step first — the grouped search is the first action.
    (A realistic "human protein kinases" phrasing is multi-step — resolve concept, THEN group —
    which a first-call grader can't score; that belongs in the end-to-end rcsb_pdb_eval.xml.)
  -->
  <probe id="group-by-uniprot" probes="group_by=uniprot mechanic: must also set return_type=polymer_entity">
    <prompt>Using the InterPro id IPR000719 (protein-kinase domain) directly — no concept lookup needed — search PDB polymer entities carrying that domain and return ONE representative per UniProt accession, keeping the best-resolution structure.</prompt>
    <expect>
      <arg name="group_by" set="true"/>
      <arg name="return_type" equals="polymer_entity"/>
    </expect>
  </probe>

  <probe id="sort-sortable" probes="sort_by sortability + direction">
    <prompt>Show human hemoglobin structures, best resolution first.</prompt>
    <expect>
      <arg name="sort_by" contains="resolution_combined"/>
      <arg name="sort_direction" equals="asc" default="asc"/>
    </expect>
  </probe>

  <probe id="sequence" probes="sequence service selection">
    <prompt>Find proteins with a sequence similar to MVLSPADKTNVKAAWGKVGAHAGEYGAEALERMFLSFPTTKTYFPHF.</prompt>
    <expect tool="rcsb_search_by_sequence">
      <arg name="sequence" set="true"/>
    </expect>
  </probe>

  <probe id="chem-smiles" probes="chemical descriptor">
    <prompt>Find chemical components matching the SMILES c1ccccc1O.</prompt>
    <expect tool="rcsb_search_by_chemical">
      <arg name="query_type" equals="descriptor" default="descriptor"/>
    </expect>
  </probe>

  <probe id="chem-formula" probes="chemical formula">
    <prompt>Which chemical components have the molecular formula C8H9NO2?</prompt>
    <expect tool="rcsb_search_by_chemical">
      <arg name="query_type" equals="formula"/>
    </expect>
  </probe>

  <probe id="shape" probes="whole-shape structure service">
    <prompt>Find structures with a 3D shape similar to entry 4HHB.</prompt>
    <expect tool="rcsb_search_by_structure">
      <arg name="entry_id" equals="4HHB" ignore-case="true"/>
    </expect>
  </probe>

  <!--
    First-call routing probe for strucmotif. Residues are given as mmCIF label ids, but the
    strucmotif docstring itself tells the model to resolve label ids via
    rcsb_get_polymer_entity_instances first — so BOTH a direct strucmotif call AND that
    sanctioned prerequisite count as correct routing into the strucmotif workflow; only a
    mis-route to by_structure (whole shape) / by_seqmotif (sequence) / a text search fails.
  -->
  <probe id="strucmotif" probes="routes to the strucmotif workflow (direct call or label-id resolution first)">
    <prompt>Find OTHER structures whose 3D residue geometry matches the catalytic triad of 4CHA — the same spatial arrangement of chain A residues at mmCIF label positions 57, 102, 195.</prompt>
    <expect tool-in="rcsb_search_strucmotif,rcsb_get_polymer_entity_instances"/>
  </probe>

  <probe id="all-hits" probes="all_hits vs paging on an explicit ALL request">
    <prompt>Give me ALL human structures released in 2024 — the complete list.</prompt>
    <expect>
      <arg name="all_hits" equals="true"/>
    </expect>
  </probe>

  <!--
    Multi-turn: seed the model with a zero-count attribute result, then ask a follow-up.
    Passing = it does NOT switch to a keyword search (the 'empty result is valid' gotcha).
  -->
  <probe id="empty-valid" probes="empty-result-is-valid (don't fall back to fulltext)" seed="zero-result">
    <prompt>Are there any structures of protein X from organism Y at better than 0.5 Angstrom?</prompt>
    <expect tool-not="rcsb_search_fulltext"/>
  </probe>

</probes>
